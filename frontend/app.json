{
  "expo": {
    "name": "KCAU LMS",
    "slug": "kcau-lms",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B3E"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.kcau.lms"
    },
    "android": {
      "versionCode": 1,
      "package": "com.kcau.lms",
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "description": "KCAU Learning Management System - Mobile & Web"
  }
}
